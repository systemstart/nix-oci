{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "before 9am on monday"
  ],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 7am on monday"
    ]
  },
  "packageRules": [
    {
      "matchManagers": [
        "gomod"
      ],
      "commitMessagePrefix": "fix(deps):"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "commitMessagePrefix": "ci(deps):"
    },
    {
      "matchManagers": [
        "nix"
      ],
      "commitMessagePrefix": "chore(deps):"
    },
    {
      "matchManagers": [
        "nix"
      ],
      "matchPackageNames": [
        "nixpkgs"
      ],
      "commitMessageExtra": "({{{newVersion}}})"
    }
  ]
}
